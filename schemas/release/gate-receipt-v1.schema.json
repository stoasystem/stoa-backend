{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stoa.invalid/schemas/release/gate-receipt-v1.schema.json",
  "title": "STOA closed release gate receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "gate_id",
    "source",
    "command",
    "runtime",
    "inputs",
    "result",
    "gate_evidence",
    "privacy",
    "started_at",
    "ended_at",
    "receipt_sha256"
  ],
  "properties": {
    "schema": {"const": "stoa.release.gate-receipt.v1"},
    "gate_id": {
      "enum": [
        "gate-self-test",
        "backend-python-hermetic",
        "candidate-source",
        "backend-python-standard",
        "backend-python-future",
        "backend-ruff",
        "backend-mypy",
        "backend-dependencies",
        "frontend-locked-install",
        "frontend-eslint",
        "frontend-typecheck",
        "frontend-build",
        "frontend-dependencies",
        "frontend-contract",
        "frontend-playwright",
        "release-provenance",
        "artifact-integrity",
        "staging-deploy",
        "staging-smoke",
        "non-production-rollback",
        "production-approval",
        "production-deploy",
        "production-smoke",
        "production-rollback"
      ]
    },
    "source": {"$ref": "#/$defs/source"},
    "command": {"$ref": "#/$defs/command"},
    "runtime": {"$ref": "#/$defs/runtime"},
    "inputs": {"$ref": "#/$defs/inputs"},
    "result": {"$ref": "#/$defs/result"},
    "gate_evidence": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/python_matrix_evidence"}
      ]
    },
    "privacy": {"$ref": "#/$defs/privacy"},
    "started_at": {"$ref": "#/$defs/utc"},
    "ended_at": {"$ref": "#/$defs/utc"},
    "receipt_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,6})?Z$"
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?:\\.|(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*[\\r\\n]).+)$"
    },
    "repository_common": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "head",
        "tree",
        "lock_path",
        "lock_sha256",
        "porcelain_sha256",
        "clean"
      ],
      "properties": {
        "name": {"type": "string"},
        "head": {"$ref": "#/$defs/git_sha"},
        "tree": {"$ref": "#/$defs/git_sha"},
        "lock_path": {"type": "string"},
        "lock_sha256": {"$ref": "#/$defs/sha256"},
        "porcelain_sha256": {"$ref": "#/$defs/sha256"},
        "clean": {"const": true}
      }
    },
    "backend_repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "head",
        "tree",
        "lock_path",
        "lock_sha256",
        "porcelain_sha256",
        "clean"
      ],
      "properties": {
        "name": {"const": "backend"},
        "head": {"$ref": "#/$defs/git_sha"},
        "tree": {"$ref": "#/$defs/git_sha"},
        "lock_path": {"const": "uv.lock"},
        "lock_sha256": {"$ref": "#/$defs/sha256"},
        "porcelain_sha256": {"$ref": "#/$defs/sha256"},
        "clean": {"const": true}
      }
    },
    "frontend_repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "head",
        "tree",
        "lock_path",
        "lock_sha256",
        "porcelain_sha256",
        "clean"
      ],
      "properties": {
        "name": {"const": "frontend"},
        "head": {"$ref": "#/$defs/git_sha"},
        "tree": {"$ref": "#/$defs/git_sha"},
        "lock_path": {"const": "package-lock.json"},
        "lock_sha256": {"$ref": "#/$defs/sha256"},
        "porcelain_sha256": {"$ref": "#/$defs/sha256"},
        "clean": {"const": true}
      }
    },
    "infra_repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "head",
        "tree",
        "lock_path",
        "lock_sha256",
        "porcelain_sha256",
        "clean"
      ],
      "properties": {
        "name": {"const": "infra"},
        "head": {"$ref": "#/$defs/git_sha"},
        "tree": {"$ref": "#/$defs/git_sha"},
        "lock_path": {"const": "uv.lock"},
        "lock_sha256": {"$ref": "#/$defs/sha256"},
        "porcelain_sha256": {"$ref": "#/$defs/sha256"},
        "clean": {"const": true}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_identity", "repositories"],
      "properties": {
        "candidate_identity": {"$ref": "#/$defs/sha256"},
        "repositories": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {"$ref": "#/$defs/backend_repository"},
            {"$ref": "#/$defs/frontend_repository"},
            {"$ref": "#/$defs/infra_repository"}
          ],
          "items": false
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "repository", "cwd", "argv"],
      "properties": {
        "name": {"enum": ["verify", "self-test"]},
        "repository": {"enum": ["backend", "frontend", "infra"]},
        "cwd": {"$ref": "#/$defs/relative_path"},
        "argv": {
          "type": "array",
          "minItems": 2,
          "maxItems": 32,
          "items": {"type": "string", "minLength": 1, "maxLength": 512}
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "platform", "clock"],
      "properties": {
        "python": {"type": "string", "pattern": "^3\\.[0-9]+\\.[0-9]+$"},
        "platform": {"type": "string", "minLength": 3, "maxLength": 80},
        "clock": {"$ref": "#/$defs/utc"}
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "path", "bytes", "sha256"],
      "properties": {
        "repository": {"enum": ["backend", "frontend", "infra"]},
        "path": {"$ref": "#/$defs/relative_path"},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts", "configs"],
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identity"}
        },
        "configs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identity"}
        }
      }
    },
    "python_matrix_input_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bytes", "sha256"],
      "properties": {
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "python_matrix_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pyproject.toml", "uv.lock", "requirements.txt"],
      "properties": {
        "pyproject.toml": {"$ref": "#/$defs/python_matrix_input_identity"},
        "uv.lock": {"$ref": "#/$defs/python_matrix_input_identity"},
        "requirements.txt": {"$ref": "#/$defs/python_matrix_input_identity"}
      }
    },
    "python_matrix_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "error", "skipped", "xfail", "xpass"],
      "properties": {
        "total": {"type": "integer", "minimum": 1},
        "passed": {"type": "integer", "minimum": 1},
        "failed": {"const": 0},
        "error": {"const": 0},
        "skipped": {"const": 0},
        "xfail": {"const": 0},
        "xpass": {"const": 0}
      }
    },
    "python_matrix_run_1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run", "environment", "clock", "seed", "runtime", "lock_sha256", "collection_sha256", "counts"],
      "properties": {
        "run": {"const": 1},
        "environment": {"const": "fresh-1"},
        "clock": {"const": "2026-07-01T12:00:00Z"},
        "seed": {"const": 4740718},
        "runtime": {"type": "string", "pattern": "^3\\.12\\.[0-9]+$"},
        "lock_sha256": {"$ref": "#/$defs/sha256"},
        "collection_sha256": {"$ref": "#/$defs/sha256"},
        "counts": {"$ref": "#/$defs/python_matrix_counts"}
      }
    },
    "python_matrix_run_2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run", "environment", "clock", "seed", "runtime", "lock_sha256", "collection_sha256", "counts"],
      "properties": {
        "run": {"const": 2},
        "environment": {"const": "fresh-2"},
        "clock": {"const": "2035-01-15T12:00:00Z"},
        "seed": {"const": 4740718},
        "runtime": {"type": "string", "pattern": "^3\\.12\\.[0-9]+$"},
        "lock_sha256": {"$ref": "#/$defs/sha256"},
        "collection_sha256": {"$ref": "#/$defs/sha256"},
        "counts": {"$ref": "#/$defs/python_matrix_counts"}
      }
    },
    "python_matrix_runs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {"$ref": "#/$defs/python_matrix_run_1"},
        {"$ref": "#/$defs/python_matrix_run_2"}
      ],
      "items": false
    },
    "python_matrix_pass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "seed", "clocks", "source", "suite_argv", "status", "reason_code", "runs"],
      "properties": {
        "schema": {"const": "stoa.phase474.python-matrix.v1"},
        "seed": {"const": 4740718},
        "clocks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"const": "2026-07-01T12:00:00Z"},
            {"const": "2035-01-15T12:00:00Z"}
          ],
          "items": false
        },
        "source": {"$ref": "#/$defs/python_matrix_source"},
        "suite_argv": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {"const": "python"},
            {"const": "-m"},
            {"const": "pytest"},
            {"const": "-q"},
            {"const": "-p"},
            {"const": "no:socket"}
          ],
          "items": false
        },
        "status": {"const": "PASS"},
        "reason_code": {"const": null},
        "runs": {"$ref": "#/$defs/python_matrix_runs"}
      }
    },
    "python_matrix_not_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "seed", "clocks", "source", "suite_argv", "status", "reason_code", "runs"],
      "properties": {
        "schema": {"const": "stoa.phase474.python-matrix.v1"},
        "seed": {"const": 4740718},
        "clocks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"const": "2026-07-01T12:00:00Z"},
            {"const": "2035-01-15T12:00:00Z"}
          ],
          "items": false
        },
        "source": {"$ref": "#/$defs/python_matrix_source"},
        "suite_argv": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {"const": "python"},
            {"const": "-m"},
            {"const": "pytest"},
            {"const": "-q"},
            {"const": "-p"},
            {"const": "no:socket"}
          ],
          "items": false
        },
        "status": {"const": "NOT RUN"},
        "reason_code": {"const": "OS_NETWORK_BOUNDARY_UNAVAILABLE"},
        "runs": {"type": "array", "maxItems": 0}
      }
    },
    "python_matrix_rejected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "seed", "clocks", "source", "suite_argv", "status", "reason_code", "runs", "diagnostic"],
      "properties": {
        "schema": {"const": "stoa.phase474.python-matrix.v1"},
        "seed": {"const": 4740718},
        "clocks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"const": "2026-07-01T12:00:00Z"},
            {"const": "2035-01-15T12:00:00Z"}
          ],
          "items": false
        },
        "source": {"$ref": "#/$defs/python_matrix_source"},
        "suite_argv": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {"const": "python"},
            {"const": "-m"},
            {"const": "pytest"},
            {"const": "-q"},
            {"const": "-p"},
            {"const": "no:socket"}
          ],
          "items": false
        },
        "status": {"const": "REJECTED"},
        "reason_code": {"const": "COLLECTION_IDENTITY_DRIFT"},
        "runs": {"$ref": "#/$defs/python_matrix_runs"},
        "diagnostic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["field", "run_1", "run_2"],
          "properties": {
            "field": {"const": "collection_sha256"},
            "run_1": {"$ref": "#/$defs/sha256"},
            "run_2": {"$ref": "#/$defs/sha256"}
          }
        }
      }
    },
    "python_matrix_evidence": {
      "oneOf": [
        {"$ref": "#/$defs/python_matrix_pass"},
        {"$ref": "#/$defs/python_matrix_not_run"},
        {"$ref": "#/$defs/python_matrix_rejected"}
      ]
    },
    "pass_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "errors", "skipped", "xfail", "xpass"],
      "properties": {
        "total": {"type": "integer", "minimum": 1},
        "passed": {"type": "integer", "minimum": 1},
        "failed": {"const": 0},
        "errors": {"const": 0},
        "skipped": {"const": 0},
        "xfail": {"const": 0},
        "xpass": {"const": 0}
      }
    },
    "failure_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "errors", "skipped", "xfail", "xpass"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "errors": {"type": "integer", "minimum": 0},
        "skipped": {"type": "integer", "minimum": 0},
        "xfail": {"type": "integer", "minimum": 0},
        "xpass": {"type": "integer", "minimum": 0}
      }
    },
    "zero_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "errors", "skipped", "xfail", "xpass"],
      "properties": {
        "total": {"const": 0},
        "passed": {"const": 0},
        "failed": {"const": 0},
        "errors": {"const": 0},
        "skipped": {"const": 0},
        "xfail": {"const": 0},
        "xpass": {"const": 0}
      }
    },
    "pass_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "classification", "exit_code", "reason_code", "outcomes", "stdout_sha256", "stderr_sha256"],
      "properties": {
        "status": {"const": "PASS"},
        "classification": {"const": "COMPLETE_PASS"},
        "exit_code": {"const": 0},
        "reason_code": {"const": null},
        "outcomes": {"$ref": "#/$defs/pass_counts"},
        "stdout_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "policy_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "classification", "exit_code", "reason_code", "outcomes", "stdout_sha256", "stderr_sha256"],
      "properties": {
        "status": {"const": "FAIL"},
        "classification": {"const": "POLICY_REJECTION"},
        "exit_code": {"const": 2},
        "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"},
        "outcomes": {"$ref": "#/$defs/failure_counts"},
        "stdout_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "execution_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "classification", "exit_code", "reason_code", "outcomes", "stdout_sha256", "stderr_sha256"],
      "properties": {
        "status": {"const": "FAIL"},
        "classification": {"const": "EXECUTION_FAILURE"},
        "exit_code": {"const": 3},
        "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"},
        "outcomes": {"$ref": "#/$defs/failure_counts"},
        "stdout_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "not_run_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "classification", "exit_code", "reason_code", "outcomes", "stdout_sha256", "stderr_sha256"],
      "properties": {
        "status": {"const": "NOT RUN"},
        "classification": {"const": "NOT_RUN_OBLIGATION"},
        "exit_code": {"const": 2},
        "reason_code": {
          "enum": [
            "EXTERNAL_CHECK_UNAVAILABLE",
            "PRODUCTION_OPERATION_NOT_AUTHORIZED"
          ]
        },
        "outcomes": {"$ref": "#/$defs/zero_counts"},
        "stdout_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "result": {
      "oneOf": [
        {"$ref": "#/$defs/pass_result"},
        {"$ref": "#/$defs/policy_result"},
        {"$ref": "#/$defs/execution_result"},
        {"$ref": "#/$defs/not_run_result"}
      ]
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "scanned_field_count",
        "match_count",
        "environment_values_serialized",
        "secret_values_serialized"
      ],
      "properties": {
        "passed": {"const": true},
        "scanned_field_count": {"type": "integer", "minimum": 1},
        "match_count": {"const": 0},
        "environment_values_serialized": {"const": false},
        "secret_values_serialized": {"const": false}
      }
    }
  }
}
