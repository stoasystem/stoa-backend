{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stoa.invalid/schemas/release/dependency-exceptions-v1.schema.json",
  "title": "STOA exact dependency exception ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "exceptions"],
  "properties": {
    "schema": {"const": "stoa.release.dependency-exceptions.v1"},
    "exceptions": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ecosystem",
          "package",
          "advisory",
          "installed_version",
          "lock_sha256",
          "dependency_scope",
          "severity",
          "reachability",
          "reachability_evidence",
          "owner",
          "expires_at",
          "target"
        ],
        "properties": {
          "ecosystem": {"enum": ["backend-python", "frontend-npm"]},
          "package": {
            "type": "string",
            "minLength": 1,
            "maxLength": 214,
            "pattern": "^(?!.*[*>~=])[a-z0-9@][a-z0-9._@/-]*$"
          },
          "advisory": {
            "type": "string",
            "minLength": 3,
            "maxLength": 120,
            "pattern": "^(?!.*[*?])[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "installed_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "pattern": "^(?!.*[*?<>~=,;\\s]).+$"
          },
          "lock_sha256": {"$ref": "#/$defs/sha256"},
          "dependency_scope": {
            "enum": ["runtime", "web-root-production", "web-root-development"]
          },
          "severity": {"enum": ["unavailable", "critical", "high", "moderate"]},
          "reachability": {"enum": ["production-reachable", "proven-unreachable"]},
          "reachability_evidence": {
            "type": "string",
            "minLength": 16,
            "maxLength": 400,
            "pattern": "^(?!.*[*?])[A-Za-z0-9][A-Za-z0-9 ./_:#()-]*$"
          },
          "owner": {
            "type": "string",
            "minLength": 3,
            "maxLength": 80,
            "pattern": "^(?!.*[*?])[A-Za-z0-9][A-Za-z0-9._@-]*$"
          },
          "expires_at": {"$ref": "#/$defs/utc"},
          "target": {
            "type": "string",
            "minLength": 12,
            "maxLength": 240,
            "pattern": "^(?=.*(?:upgrade|remove|replace))(?!.*[*?])[A-Za-z0-9][A-Za-z0-9 ._@:/()+-]*$"
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
