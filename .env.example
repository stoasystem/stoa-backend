# Application
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]

# AWS
AWS_REGION=eu-central-2
AWS_ACCOUNT_ID=

# DynamoDB
DYNAMODB_TABLE_NAME=stoa-main

# S3
S3_IMAGES_BUCKET=stoa-images
S3_REPORTS_BUCKET=stoa-reports
S3_PRESIGN_EXPIRY_SECONDS=300
FREE_TRIAL_DAYS=14
FREE_ATTACHMENT_STORAGE_BYTES=5368709120
PAID_ATTACHMENT_STORAGE_BYTES=16106127360

# Cognito User Pool
COGNITO_USER_POOL_ID=eu-central-2_XXXXXXXXX
COGNITO_STUDENT_CLIENT_ID=
COGNITO_PARENT_CLIENT_ID=
COGNITO_TEACHER_CLIENT_ID=
COGNITO_ADMIN_CLIENT_ID=

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=2048

# Usage limits (questions per day)
FREE_TIER_DAILY_QUESTION_LIMIT=5
STANDARD_TIER_DAILY_QUESTION_LIMIT=30
PREMIUM_TIER_DAILY_QUESTION_LIMIT=100

# SQS
TEACHER_QUEUE_URL=

# Stripe checkout callback policy
# Sandbox/test credentials and Price IDs must be supplied outside source control.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STUDENT_PRICE_ID=
STRIPE_TEACHER_SUPPORTED_PRICE_ID=
STRIPE_FAMILY_PRICE_ID=
STRIPE_LIVE_CHARGES_ENABLED=false
# Production: ["https://app.stoaedu.ch"]
# Staging: ["https://staging.stoaedu.ch"]
# Development permits only the explicitly listed loopback origin-port tuples.
STRIPE_CHECKOUT_WEB_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://[::1]:5173"]
STRIPE_CHECKOUT_RESULT_PATH=/billing/checkout/result
