{
  "expo": {
    "name": "STOA",
    "slug": "stoa-mobile",
    "scheme": "stoa",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stoa.mobile"
    },
    "android": {
      "package": "com.stoa.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#9f2638"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "${EXPO_PUBLIC_STOA_EXPO_PROJECT_ID}"
      }
    }
  }
}
